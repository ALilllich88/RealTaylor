generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model FavoritePlace {
  id        String   @id @default(cuid())
  name      String
  address   String?
  city      String?
  state     String?
  zip       String?
  category  String? // Home, Office, Client, Government, Other
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tripsFrom MileageEntry[] @relation("TripFrom")
  tripsTo   MileageEntry[] @relation("TripTo")
}

model MileageEntry {
  id              String        @id @default(cuid())
  date            DateTime
  fromPlaceId     String?
  fromPlace       FavoritePlace? @relation("TripFrom", fields: [fromPlaceId], references: [id], onDelete: SetNull)
  fromAddress     String? // For one-time addresses not saved as favorites
  toPlaceId       String?
  toPlace         FavoritePlace? @relation("TripTo", fields: [toPlaceId], references: [id], onDelete: SetNull)
  toAddress       String? // For one-time addresses not saved as favorites
  calculatedMiles Float?
  actualMiles     Float
  isRoundTrip     Boolean       @default(false)
  entity          String // Lillich Holdings, Lillich Properties, AJL Investments, Taylor Lillich Realtor, Personal, Other
  entityOther     String? // Free text if entity is "Other"
  description     String
  notes           String?
  autoHoursEntry  HoursEntry?   @relation("AutoLoggedFromTrip")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model HoursEntry {
  id             String        @id @default(cuid())
  date           DateTime
  entity         String // Lillich Holdings, Lillich Properties, AJL Investments, Taylor Lillich Realtor, Other
  entityOther    String? // Free text if entity is "Other"
  activityType   String // Property Management, Leasing, Showings, Marketing, Admin, Maintenance, Travel, Education, Other
  activityOther  String? // Free text if activity type is "Other"
  hours          Float // Decimal hours (1.5 = 1 hr 30 min)
  description    String
  notes          String?
  isAutoLogged   Boolean       @default(false) // True if auto-generated from a mileage entry
  mileageEntryId String?       @unique // Links back to the mileage entry that created this
  mileageEntry   MileageEntry? @relation("AutoLoggedFromTrip", fields: [mileageEntryId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model DistanceCache {
  id          String   @id @default(cuid())
  fromAddress String
  toAddress   String
  miles       Float
  createdAt   DateTime @default(now())

  @@unique([fromAddress, toAddress])
}
